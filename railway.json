{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20"]
        },
        "build": {
          "cmds": [
            "cd keyword-trend-api && npm install",
            "cd keyword-trend-api && npx prisma generate",
            "cd keyword-trend-api && npm run build"
          ]
        }
      },
      "start": {
        "cmd": "cd keyword-trend-api && npm start"
      }
    }
  },
  "deploy": {
    "startCommand": "cd keyword-trend-api && npm start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
