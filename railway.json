{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd keyword-trend-api && npm install && npm run build",
    "nixpacksPlan": {
      "phases": {
        "build": {
          "cmds": ["cd keyword-trend-api && npm install && npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd keyword-trend-api && npm start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
