{
  "projects": [
    {
      "name": "leanforge-api",
      "root": "keyword-trend-api",
      "build": {
        "builder": "nixpacks",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "startCommand": "npm start",
        "healthcheckPath": "/api/health",
        "restartPolicyType": "on_failure"
      }
    },
    {
      "name": "leanforge-frontend",
      "root": "leanforge-frontend",
      "build": {
        "builder": "nixpacks",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "startCommand": "npm start",
        "healthcheckPath": "/api/health",
        "restartPolicyType": "on_failure"
      }
    }
  ]
}
