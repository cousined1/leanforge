# Frontend (Vite) environment variables.
# These are inlined into the CLIENT bundle at build time — only put values here
# that are safe to expose publicly. The InsForge ANON key is browser-safe;
# never put the InsForge admin/API key here. Real values go in a local .env
# (gitignored) and in the Railway build environment.

# InsForge auth (Phase 1)
#   URL:      the `oss_host` field in .insforge/project.json
#   ANON KEY: npx @insforge/cli secrets get ANON_KEY
VITE_INSFORGE_URL=https://your-project.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key_here
