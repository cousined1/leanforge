# InsForge (if needed for future auth integration)
# INSFORGE_API_KEY=YOUR_INSFORGE_API_KEY_HERE
# INSFORGE_BASE_URL=https://your-insforge-instance.up.railway.app

# CORS — comma-separated list of allowed origins. Falls back to FRONTEND_URL only.
# Required in production to prevent silent fallback to a single origin.
# CORS_ORIGINS=https://lean-forge.net,https://www.lean-forge.net

# Database — Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXXXX.us-east-2.aws.neon.tech/keyword_trends?sslmode=require

# Redis — Upstash
# ⚠️ PRODUCTION: Use rediss:// (TLS) not redis://. Non-TLS connections will be rejected.
REDIS_URL=rediss://default:PASSWORD@us1-xxxxx.upstash.io:6379

# Serper.dev (search volume + SERP data)
SERPER_API_KEY=YOUR_SERPER_KEY

# API Key for mutating endpoints (POST/PUT/DELETE). Min 32 chars.
API_SECRET_KEY=YOUR_SECURE_API_KEY_HERE_MIN_32_CHARS
# Optional second key accepted during rotation windows. Min 32 chars.
API_SECRET_KEY_NEXT=

# Monitoring (optional but recommended in production)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Partner CTA
REGENT_PARTNER_URL=https://seo-ai-regent.com/?ref=keyword-trend-api

# Server
PORT=3001
NODE_ENV=development
RAILWAY_STATIC_URL=https://keyword-trend-api.up.railway.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ANONYMIZE_LOG_IPS=true
ENFORCE_HTTPS=false

# Cron schedule (every 6 hours)
TREND_POLL_CRON=0 */6 * * *

# InsForge (server-side JWT validation, Phase 1)
# Required for any /api/v1/auth/* route to function.
INSFORGE_URL=https://28he5ctp.us-east.insforge.app
INSFORGE_ANON_KEY=ik_8dc6f90c17d1c8c89a9819cbe0191888

# Stripe (Phase 2) — set on Railway `leanforge-api` before deploy
STRIPE_SECRET_KEY=sk_test_replace_at_deploy
STRIPE_WEBHOOK_SECRET=whsec_replace_at_deploy
STRIPE_PRICE_ID_STARTER=price_replace_at_deploy
STRIPE_PRICE_ID_GROWTH=price_replace_at_deploy
FRONTEND_URL=https://lean-forge.net
